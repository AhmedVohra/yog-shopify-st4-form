# Shopify store settings
SHOPIFY_STORE=your-store.myshopify.com
# App client secret — used to verify App Proxy signatures (and OAuth if enabled).
# This is the only Shopify credential production needs now that signed PDFs
# go to SharePoint instead of Shopify Files.
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional / legacy (only for dev utilities & OAuth mode):
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_ID=your_shopify_client_id
SESSION_SECRET=your_random_session_secret
APP_URL=https://your-app-domain.com
PORT=3001

# When set to 1 (production), /proxy/* requests without a valid Shopify
# App Proxy signature are rejected with 401.
REQUIRE_PROXY_SIGNATURE=0

# Skip the auto-started localtunnel (it is skipped automatically on Azure)
DISABLE_TUNNEL=0

# Microsoft Graph — SharePoint storage. Entra app registration in the
# MERCHANT's own tenant (client-credentials), needs application permission
# Sites.ReadWrite.All (or Sites.Selected + a grant on the target site), with
# admin consent. This is where the merchant's document library actually is,
# so it can't be swapped for a shared/vendor tenant like MAIL_* below can.
MS_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_SECRET=your_entra_client_secret

# SharePoint target: either give the Graph IDs directly...
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
# ...or let the server resolve them from hostname + site path + library name:
SHAREPOINT_HOSTNAME=contoso.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/YourSite
SHAREPOINT_LIBRARY=Documents
# Optional folder inside the library to drop signed PDFs into:
SHAREPOINT_FOLDER=

# Microsoft Graph — email sending. A SEPARATE Entra app registration/tenant
# from MS_* above, on purpose: this app is sold to multiple merchants, and
# waiting on each one to grant Mail.Send (application permission, admin
# consent) in their own tenant would block testing and onboarding. Point
# these at OUR OWN tenant + a mailbox we control to send immediately with
# zero merchant setup; a given deployment can be switched later to send as
# the merchant's own domain by repointing these four vars at their tenant
# instead (once they grant Mail.Send and hand us a mailbox) — nothing else
# changes. Only used when a customer form submission includes an ?email= param.
# MAIL_FROM must be a real, licensed Exchange Online mailbox (Microsoft 365
# Business Basic or higher) in MAIL_TENANT_ID — an unlicensed account fails
# with MailboxNotEnabledForRESTAPI even with a valid token and Mail.Send.
MAIL_TENANT_ID=00000000-0000-0000-0000-000000000000
MAIL_CLIENT_ID=00000000-0000-0000-0000-000000000000
MAIL_CLIENT_SECRET=your_entra_client_secret
MAIL_FROM=noreply@yourcompany.com
